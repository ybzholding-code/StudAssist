# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google Places API — for live reviews on the website
# Enable "Places API (New)" in Google Cloud Console and unrestrict the key for places.googleapis.com
VITE_GOOGLE_PLACES_API_KEY="AIzaSyD8uQCTpFPOf5t5c95sYaFT-dkiI1mC11A"
VITE_GOOGLE_PLACE_ID="ChIJM6IqSDY2fccRhQ6JRqE8a4M"

# ─── CONTACT FORM (Leads) ───────────────────────────────────────────────
# Resend — sends email notification to hello@studassist.ma
# NOTE: With onboarding@resend.dev, emails only deliver to the Resend account owner.
# To send to any email: verify studassist.ma domain at https://resend.com/domains
RESEND_API_KEY="re_YOUR_RESEND_API_KEY"

# Google Sheets — leads are saved via a Google Apps Script deployed on the sheet
# Sheet: https://docs.google.com/spreadsheets/d/1XhIinHKRP6e4B1Nadr5OrZ-bnzE7atN8HMQJP1HjOmg/edit
# Deploy the script in scripts/google-apps-script-leads.js as a Web App
GOOGLE_APPS_SCRIPT_URL="https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec"

# ─── CANDIDATURE FORM (Talent / Nous Rejoindre) ─────────────────────────
# Separate Resend key for talent acquisition emails
RESEND_TALENT_API_KEY="re_YOUR_TALENT_RESEND_API_KEY"

# Google Sheets — candidatures are saved via a separate Apps Script
# Sheet: https://docs.google.com/spreadsheets/d/1lp0iDSSU-l__mygE3XmtKSKPc1pxvnNhmz7yNlh5y4k/edit
# Deploy the script in scripts/google-apps-script-talent.js as a Web App
TALENT_APPS_SCRIPT_URL="https://script.google.com/macros/s/YOUR_TALENT_SCRIPT_ID/exec"

# ─── CHATBOT ────────────────────────────────────────────────────────────
# Groq API — Chatbot AI assistant key
GROQ_API_KEY="your_groq_api_key_here"


