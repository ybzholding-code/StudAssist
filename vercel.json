{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd studassist-pro && npm install && npm run build",
  "outputDirectory": "studassist-pro/dist",
  "installCommand": "echo skip-root-install",
  "framework": null,
  "rewrites": [
    { "source": "/((?!api/|assets/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.ts": {
      "runtime": "nodejs20.x"
    }
  }
}
